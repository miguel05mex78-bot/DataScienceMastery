        "# Deployment of the predictive model\n",
        "# Import the necessary libraries\n",
        "import pandas as pd\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.ensemble import RandomForestClassifier\n",
        "from sklearn.metrics import accuracy_score\n",
        "import joblib"
      ],
      "metadata": {
        "id": "OACeF0kCh9nt"
      },
      "execution_count": 41,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Split the data into training and testing sets\n",
        "X_train, X_test, y_train, y_test = train_test_split(data.drop('Survived', axis=1), data['Survived'], test_size=0.2, random_state=42)\n",
        "\n",
        "# Train a Random Forest model\n",
        "random_forest = RandomForestClassifier()\n",
        "random_forest.fit(X_train, y_train)\n",
        "\n",
        "# Save the trained model\n",
        "joblib.dump(random_forest, 'random_forest_model.pkl')\n",
        "\n",
        "# Load the saved model\n",
        "loaded_model = joblib.load('random_forest_model.pkl')\n",
        "\n",
        "# Make predictions using the loaded model\n",
        "predictions = loaded_model.predict(X_test)\n",
        "\n",
        "# Evaluate the model's performance\n",
        "accuracy = accuracy_score(y_test, predictions)\n",
        "print(f\"Accuracy: {accuracy}\")\n",
        "\n",
        "# Analyze feature importance\n",
        "feature_importance = loaded_model.feature_importances_\n",
        "feature_names = X_train.columns\n",
        "\n",
        "# Create a DataFrame to display feature importance\n",
        "feature_importance_df = pd.DataFrame({'Feature': feature_names, 'Importance': feature_importance})\n",
        "feature_importance_df = feature_importance_df.sort_values(by='Importance', ascending=False)\n",
        "\n",
        "print(\"Feature Importance:\")\n",
        "print(feature_importance_df)\n",
        "\n",
        "# When choosing characteristics (features) for your Machine Learning model, you usually keep the ones with the highest Feature Importance and remove those with very low or zero importance\n",
        "# Based on your importance values, the most useful characteristics are:\n",
        "\n",
        "# Sex\n",
        "\n",
        "# Age\n",
        "\n",
        "# Fare\n",
        "\n",
        "# These variables are well-known strong predictors for Titanic survival."
